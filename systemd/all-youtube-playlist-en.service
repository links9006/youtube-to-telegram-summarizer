[Unit]
Description=All YouTube EN playlist producer
After=network.target

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/all-youtube
EnvironmentFile=/home/ubuntu/all-youtube/.env
ExecStart=/bin/bash -lc '/home/ubuntu/all-youtube/.venv/bin/python -m app.producer_playlist --language en --playlist-url "$PLAYLIST_EN_URL" --source-type playlist_en'