# ─── Telegram bot ───────────────────────────────────────────────────────
BOT_TOKEN=
USE_WEBHOOK=1
WEBHOOK_BASE_URL=https://your-public-domain.example.com
WEBHOOK_PATH=/yt/
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8081
STEP1_SERVICE_HOST=127.0.0.1
STEP1_SERVICE_PORT=8091

# ─── Telegram user session (Telethon, for audio extraction) ─────────────
# Get API_ID/API_HASH at https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION=/opt/all-youtube/telegram_session
TELEGRAM_PUBLISHER_SESSION=/opt/all-youtube/telegram_publisher_session
TELEGRAM_PUBLISHER_STRING_SESSION=
TOPSAVERS_BOT_USERNAME=topsaversbot

# ─── LLM / transcription providers ──────────────────────────────────────
HUGGINGFACE_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODELS=openrouter/owl-alpha,nvidia/nemotron-3-ultra-550b-a55b:free,nex-agi/nex-n2-pro:free,poolside/laguna-m.1:free,nvidia/nemotron-3-super-120b-a12b:free
YOUTUBE_API_KEY=

# ─── Destination channels (your bot must be an admin here) ──────────────
TARGET_CHANNEL=@your_main_channel
DIGEST_SOURCE_CHANNEL=@your_main_channel
DIGEST_TARGET_CHANNEL=@your_digest_channel
DIGEST_POLL_SECONDS=300
DIGEST_TELEGRAM_SEND_DELAY_SECONDS=3
DIGEST_BOOTSTRAP_LIMIT=10

# ─── Ingest sources ─────────────────────────────────────────────────────
PLAYLIST_RU_URL=https://youtube.com/playlist?list=YOUR_RU_PLAYLIST_ID
PLAYLIST_EN_URL=https://youtube.com/playlist?list=YOUR_EN_PLAYLIST_ID
SEARCH_QUERIES=ai tools,ai service,ai news
SEARCH_MAX_RESULTS=4
BACKLOG_FILES=/opt/all-youtube/backlog/download.txt
BACKLOG_PROCESSED_DIR=/opt/all-youtube/backlog/processed/

# ─── Storage paths ──────────────────────────────────────────────────────
DB_PATH=/opt/all-youtube/data/all_youtube.sqlite3
DOWNLOAD_DIR=/opt/all-youtube/data/downloads
STEP1_CACHE_DIR=/opt/all-youtube/data/downloads/step1_service
TRANSCRIPTS_DIR=/opt/all-youtube/data/transcripts
LOG_DIR=/opt/all-youtube/logs
WHISPER_MODELS=turbo,small
GIGAAM_CHUNK_SECONDS=30
